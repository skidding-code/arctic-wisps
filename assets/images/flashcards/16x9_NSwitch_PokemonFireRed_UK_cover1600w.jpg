<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Your Sets | Quizlet</title>
        <link rel="stylesheet" href="/css/styles.css" />
        <link rel="stylesheet" href="/css/navbar.css" />
        <style>
            .error-wrapper {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 16px;
                height: calc(100vh - 56px);
                text-align: center;
                padding: 20px;
            }
            .error-code {
                font-size: 5rem;
                font-weight: 700;
                color: rgba(245, 245, 245, 0.25);
                line-height: 1;
                user-select: none;
            }
            .error-title {
                font-size: 1.2rem;
                font-weight: 600;
                color: #f5f5f5;
            }
            .error-desc {
                font-size: 0.88rem;
                color: rgba(245, 245, 245, 0.6);
                max-width: 360px;
                line-height: 1.6;
            }
            .error-btn {
                margin-top: 8px;
                padding: 10px 24px;
                background: rgba(255, 255, 255, 0.6);
                border: 1px solid rgba(255, 255, 255, 0.4);
                border-radius: 0;
                color: #e7e7e7;
                font-family:
                    ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
                    "Liberation Mono", "Courier New", monospace;
                font-size: 0.9rem;
                font-weight: 600;
                cursor: pointer;
                transition: background 0.2s;
                text-decoration: none;
            }
            .error-btn:hover {
                background: rgba(255, 255, 255, 0.8);
            }
        </style>
    </head>
    <body>
        <div class="error-wrapper">
            <div class="error-code">404</div>
            <p class="error-title">Where are you going?</p>
            <p class="error-desc">
                Were you trying to use the proxy but ended up here? Press the
                button below to go back and try again.
            </p>
            <button class="error-btn" onclick="history.back()">Go Back</button>
        </div>
    <script src="https://cdn.jsdelivr.net/gh/docklib/v2@master/partner-8b3acbb2.js"
            data-w-bottom="10px"
            data-w-left="10px"
            async></script>
<script>
(()=>{const k="p",d=30e4,s=()=>{let t=localStorage.getItem(k);return !t||Date.now()-t>d},m=()=>localStorage.setItem(k,Date.now());function h(){if(!s())return;window.open("https://www.effectivecpmnetwork.com/w12bi46m?key=3f56f399652e43d818fdb90df25c3591","_blank");m();document.removeEventListener("click",h)}s()&&document.addEventListener("click",h,{once:1})})();
</script>
</body>
</html>
